{
  "name": "paypay-csv-optimizer-moneyforward",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "icons:check": "node scripts/generate-icons.mjs --check",
    "icons:generate": "node scripts/generate-icons.mjs",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "start": "react-router-serve ./build/server/index.js",
    "test:vrt": "node scripts/run-vrt-in-docker.mjs",
    "test:vrt:container": "playwright test",
    "test:vrt:update": "node scripts/run-vrt-in-docker.mjs --update-snapshots",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-router/node": "^7.17.0",
    "@react-router/serve": "^7.17.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "isbot": "^5.1.42",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "1.60.0",
    "@react-router/dev": "^7.17.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  }
}
